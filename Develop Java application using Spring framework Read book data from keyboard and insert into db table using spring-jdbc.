        BookDao dao = ctx.getBean(BookDao.class);

        Scanner sc = new Scanner(System.in);

        Book b = new Book();

        System.out.println("Enter Book Id:");
        b.setBookId(sc.nextInt());

        System.out.println("Enter Book Name:");
