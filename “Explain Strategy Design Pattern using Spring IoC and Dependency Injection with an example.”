// BillPayment.java
package in.rishav.beans;

public class BillPayment {

    private IPayment payment;

    public BillPayment() {
        System.out.println("BillPayment :: Constructor");
    }

    // Setter Injection
    public void setPayment(IPayment payment) {
        this.payment = payment;
        System.out.println("setPayment() called");
        System.out.println("Injected :: " + payment.getClass().getName());
    }

    public void processBill(double amount) {
        if (payment.pay(amount)) {
            System.out.println("Bill Payment Successful");
        } else {
            System.out.println("Bill Payment Failed");
        }
    }
}
<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Payment strategy beans -->
    <bean id="cash" class="in.rishav.beans.CashPayment"/>
    <bean id="scanner" class="in.rishav.beans.ScannerPayment"/>
    <bean id="debit" class="in.rishav.beans.DebitCardPayment"/>
    <bean id="credit" class="in.rishav.beans.CreditCardPayment"/>

    <!-- BillPayment bean with setter injection -->
    <bean id="billPayment" class="in.rishav.beans.BillPayment">
        <!-- Change ref to switch payment mode -->
        <property name="payment" ref="scanner"/>
    </bean>

</beans>
