1️⃣ Country Entity
package in.rishav.springbootdemo.model;

public class Country {

    private String code;
    private String name;

    public Country(String code,String name){
        this.code = code;
        this.name = name;
    }

    public String getCode(){
        return code;
    }

    public String getName(){
        return name;
    }
}
2️⃣ DAO Layer
package in.rishav.springbootdemo.dao;

import java.util.*;
import org.springframework.stereotype.Repository;
import in.rishav.springbootdemo.model.Country;

@Repository
public class CountryDao {

    public List<Country> getAllCountries(){

        List<Country> list = new ArrayList<>();

        list.add(new Country("+91","India"));
        list.add(new Country("+1","USA"));
        list.add(new Country("+44","UK"));

        return list;
    }
}

(Here we simulate DB records.)

